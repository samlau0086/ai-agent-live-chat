generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  agent
  viewer
}

enum ConversationStatus {
  ai_active
  queued_for_human
  human_active
  resolved
  closed
}

enum MessageRole {
  visitor
  ai
  human_agent
  system
  tool
}

enum WebhookEvent {
  conversation_created
  message_created
  handoff_started
  handoff_released
  conversation_closed
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(agent)
  disabled     Boolean  @default(false)
  failedLoginCount Int   @default(0)
  lockedUntil DateTime?
  passwordChangedAt DateTime?
  forcePasswordChange Boolean @default(false)
  createdAt    DateTime @default(now())
  messages     Message[]
  auditLogs    AuditLog[]
  agentStatus  AgentStatus?
  takenConversations Conversation[]
  sentInvitations UserInvitation[] @relation("InvitationInviter")
  acceptedInvitations UserInvitation[] @relation("InvitationAcceptedUser")
}

model UserInvitation {
  id             String   @id @default(cuid())
  username       String
  role           UserRole @default(agent)
  tokenHash      String   @unique
  invitedById    String?
  acceptedUserId String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  invitedBy      User?    @relation("InvitationInviter", fields: [invitedById], references: [id])
  acceptedUser   User?    @relation("InvitationAcceptedUser", fields: [acceptedUserId], references: [id])

  @@index([username])
  @@index([expiresAt])
}

model Conversation {
  id                String             @id @default(cuid())
  visitorSessionId  String             @unique
  externalUserId    String?
  status            ConversationStatus @default(ai_active)
  subject           String?
  metadata          Json               @default("{}")
  takenOverById     String?
  takenOverAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  closedAt          DateTime?
  messages          Message[]
  tags              ConversationTag[]
  takenOverBy       User?              @relation(fields: [takenOverById], references: [id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  metadata       Json         @default("{}")
  agentId        String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          User?        @relation(fields: [agentId], references: [id])

  @@index([conversationId, createdAt])
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  name      String
  url       String
  secret    String?
  enabled   Boolean  @default(true)
  events    String[] @default([])
  retryMaxAttempts Int @default(3)
  retryBackoffSeconds Int @default(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id         String          @id @default(cuid())
  endpointId String
  event      String
  payload    Json
  status     String
  attempts   Int             @default(0)
  lastError  String?
  createdAt  DateTime        @default(now())
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

model ToolDefinition {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String
  inputSchema     Json     @default("{}")
  authConfig      Json     @default("{}")
  timeoutMs       Int      @default(5000)
  enabled         Boolean  @default(true)
  permissionScope String   @default("ai")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ToolInvocationLog {
  id             String   @id @default(cuid())
  toolName       String
  conversationId String?
  input          Json
  output         Json?
  status         String
  error          String?
  createdAt      DateTime @default(now())
}

model AIConfiguration {
  id                  String   @id @default("global")
  provider            String   @default("mock")
  model               String   @default("gpt-4o-mini")
  temperature         Float    @default(0.2)
  maxContextMessages  Int      @default(12)
  systemPrompt        String
  fallbackMessage     String
  noAnswerStrategy    String   @default("continue")
  enableKnowledgeBase Boolean  @default(true)
  enableTools         Boolean  @default(true)
  knowledgeBaseIds    String[] @default([])
  autoHandoff         Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AITrace {
  id               String   @id @default(cuid())
  conversationId   String?
  action           String
  provider         String
  model            String
  latencyMs        Int      @default(0)
  configSnapshot   Json     @default("{}")
  selectedMessages Json     @default("[]")
  knowledgeSources Json     @default("[]")
  toolNames        String[] @default([])
  toolCallPlaceholders Json  @default("[]")
  handoffReason    String?
  fallbackReason   String?
  error            String?
  replyMessageId   String?
  createdAt        DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([createdAt])
}

model SecuritySettings {
  id                          String   @id @default("global")
  failedLoginLockoutThreshold Int      @default(5)
  lockoutMinutes              Int      @default(15)
  passwordRotationDays        Int      @default(90)
  updatedAt                   DateTime @updatedAt
}

model WidgetConfiguration {
  id                       String   @id @default("global")
  themeColor               String   @default("#1f2a44")
  welcomeMessage           String   @default("Start a conversation. The AI agent will answer first, and a human can take over when needed.")
  offlineMessage           String   @default("No human agents are online right now. Leave a message and the AI agent will keep helping.")
  enableSatisfaction       Boolean  @default(true)
  enableTranscriptDownload Boolean  @default(true)
  requireEndConfirmation   Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model KnowledgeBase {
  id          String              @id @default(cuid())
  name        String
  description String?
  enabled     Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sources     KnowledgeSource[]
  documents   KnowledgeDocument[]
  chunks      KnowledgeChunk[]
  embeddings  KnowledgeEmbedding[]
}

model KnowledgeSource {
  id              String              @id @default(cuid())
  knowledgeBaseId String
  type            String              @default("manual")
  name            String
  uri             String?
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  knowledgeBase   KnowledgeBase       @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  documents       KnowledgeDocument[]
  chunks          KnowledgeChunk[]
  embeddings      KnowledgeEmbedding[]

  @@index([knowledgeBaseId])
  @@index([type])
}

model KnowledgeDocument {
  id              String           @id @default(cuid())
  knowledgeBaseId String
  sourceId        String?
  title           String
  sourceType      String           @default("manual")
  content         String
  enabled         Boolean          @default(true)
  contentHash     String?
  indexingStatus  String           @default("indexed")
  indexedAt       DateTime?
  lastIndexError  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  knowledgeBase   KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  source          KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  chunks          KnowledgeChunk[]
  embeddings      KnowledgeEmbedding[]

  @@index([knowledgeBaseId])
  @@index([sourceId])
  @@index([indexingStatus])
}

model KnowledgeChunk {
  id              String            @id @default(cuid())
  knowledgeBaseId String
  documentId      String
  sourceId        String?
  content         String
  ordinal         Int
  tokens          String[]          @default([])
  tokenCount      Int               @default(0)
  embedding       Unsupported("vector(64)")?
  createdAt       DateTime          @default(now())
  knowledgeBase   KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  source          KnowledgeSource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  embeddings      KnowledgeEmbedding[]

  @@index([knowledgeBaseId])
  @@index([documentId])
  @@index([sourceId])
}

model KnowledgeEmbedding {
  id              String             @id @default(cuid())
  knowledgeBaseId String
  sourceId        String?
  documentId      String
  chunkId         String
  provider        String             @default("none")
  model           String             @default("none")
  dimensions      Int                @default(0)
  embedding       Unsupported("vector(64)")?
  status          String             @default("pending")
  error           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  knowledgeBase   KnowledgeBase      @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  source          KnowledgeSource?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  document        KnowledgeDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunk           KnowledgeChunk     @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([chunkId, provider, model])
  @@index([knowledgeBaseId])
  @@index([sourceId])
  @@index([documentId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
}

model ConversationTag {
  id             String       @id @default(cuid())
  conversationId String
  name           String
  color          String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, name])
}

model AgentStatus {
  userId    String   @id
  status    String   @default("offline")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
