generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  agent
  viewer
}

enum ConversationStatus {
  ai_active
  queued_for_human
  human_active
  resolved
  closed
}

enum MessageRole {
  visitor
  ai
  human_agent
  system
  tool
}

enum WebhookEvent {
  conversation_created
  message_created
  handoff_started
  handoff_released
  conversation_closed
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(agent)
  disabled     Boolean  @default(false)
  createdAt    DateTime @default(now())
  messages     Message[]
  auditLogs    AuditLog[]
  agentStatus  AgentStatus?
  takenConversations Conversation[]
}

model Conversation {
  id                String             @id @default(cuid())
  visitorSessionId  String             @unique
  externalUserId    String?
  status            ConversationStatus @default(ai_active)
  subject           String?
  metadata          Json               @default("{}")
  takenOverById     String?
  takenOverAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  closedAt          DateTime?
  messages          Message[]
  tags              ConversationTag[]
  takenOverBy       User?              @relation(fields: [takenOverById], references: [id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  metadata       Json         @default("{}")
  agentId        String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          User?        @relation(fields: [agentId], references: [id])

  @@index([conversationId, createdAt])
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  name      String
  url       String
  secret    String?
  enabled   Boolean  @default(true)
  events    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id         String          @id @default(cuid())
  endpointId String
  event      String
  payload    Json
  status     String
  attempts   Int             @default(0)
  lastError  String?
  createdAt  DateTime        @default(now())
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

model ToolInvocationLog {
  id             String   @id @default(cuid())
  toolName       String
  conversationId String?
  input          Json
  output         Json?
  status         String
  error          String?
  createdAt      DateTime @default(now())
}

model AIConfiguration {
  id                  String   @id @default("global")
  provider            String   @default("mock")
  model               String   @default("gpt-4o-mini")
  temperature         Float    @default(0.2)
  maxContextMessages  Int      @default(12)
  systemPrompt        String
  fallbackMessage     String
  enableKnowledgeBase Boolean  @default(true)
  enableTools         Boolean  @default(true)
  knowledgeBaseIds    String[] @default([])
  autoHandoff         Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model KnowledgeBase {
  id          String              @id @default(cuid())
  name        String
  description String?
  enabled     Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  documents   KnowledgeDocument[]
  chunks      KnowledgeChunk[]
}

model KnowledgeDocument {
  id              String           @id @default(cuid())
  knowledgeBaseId String
  title           String
  sourceType      String           @default("manual")
  content         String
  enabled         Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  knowledgeBase   KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks          KnowledgeChunk[]

  @@index([knowledgeBaseId])
}

model KnowledgeChunk {
  id              String            @id @default(cuid())
  knowledgeBaseId String
  documentId      String
  content         String
  ordinal         Int
  tokens          String[]          @default([])
  embedding       Unsupported("vector")?
  createdAt       DateTime          @default(now())
  knowledgeBase   KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([documentId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
}

model ConversationTag {
  id             String       @id @default(cuid())
  conversationId String
  name           String
  color          String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, name])
}

model AgentStatus {
  userId    String   @id
  status    String   @default("offline")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
